{
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "buildCommand": "npx next build",
  "outputDirectory": "out",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/docs", "destination": "/api/index.py" }
  ]
}
