{
  "title": "SpecVLM Inference Overview",
  "version": 1,
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "targets": [{ "expr": "rate(specvlm_requests_total[1m])", "legendFormat": "RPS" }]
    },
    {
      "title": "Latency P50/P95/P99",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(specvlm_ttft_ms_bucket[1m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(specvlm_ttft_ms_bucket[1m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(specvlm_ttft_ms_bucket[1m]))", "legendFormat": "P99" }
      ]
    },
    {
      "title": "Token Generation Rate",
      "type": "graph",
      "targets": [{ "expr": "rate(specvlm_tokens_generated_total[1m])", "legendFormat": "Tokens/s" }]
    },
    {
      "title": "Speculative Acceptance Rate",
      "type": "gauge",
      "targets": [{ "expr": "avg(specvlm_spec_acceptance_rate)" }]
    },
    {
      "title": "GPU Memory Usage",
      "type": "graph",
      "targets": [{ "expr": "specvlm_gpu_memory_used_gb", "legendFormat": "GPU {{gpu_id}}" }]
    },
    {
      "title": "KV Cache Utilization",
      "type": "gauge",
      "targets": [{ "expr": "specvlm_kv_cache_usage_pct" }]
    }
  ]
}
